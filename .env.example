# ============================================================
# FEGESPORT — Environment Variables Template
# Copy this file to .env (local) and configure values in Netlify
# for production (Site settings → Build & deploy → Environment).
# ============================================================

# ----- Supabase (REQUIRED) -----
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# IMPORTANT SECURITY NOTE:
# - NEVER include VITE_SUPABASE_SERVICE_ROLE_KEY in this file
# - Service role key bypasses ALL RLS policies and should ONLY be used server-side
# - Only use the anon key in client-side code

# ----- Google Maps API Key (OPTIONAL) -----
# 1. Go to Google Cloud Console: https://console.cloud.google.com/
# 2. Enable Maps JavaScript API
# 3. Create an API key
# 4. Restrict the key to your domain (fegesport224.org)
# 5. Replace the value below with your own key
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ----- Admin Contact Email -----
VITE_ADMIN_EMAIL=admin@yourdomain.com

# ============================================================
# ANALYTICS (OPTIONAL — leave empty to disable)
# When set, the cookie banner appears and tracking loads
# ONLY after user consent (RGPD compliant).
# ============================================================

# ----- Google Analytics 4 -----
# Get your ID at https://analytics.google.com → Admin → Data Streams
# Format: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=

# ----- Microsoft Clarity (heatmaps + session recordings, FREE) -----
# Get your project ID at https://clarity.microsoft.com → Project ID
# Format: 10-char alphanumeric
VITE_CLARITY_PROJECT_ID=
